# ─────────────────────────────────────────────────
# NetLearn Backend — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to GitHub.
# ─────────────────────────────────────────────────

# Supabase PostgreSQL connection string
# Found in: Supabase → Project Settings → Database → Connection string (URI mode)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# Admin dashboard password — change this to something secure
ADMIN_KEY=netlearn2024

# Port (Render.com sets this automatically — leave as 3000 for local dev)
PORT=3000

# Your GitHub Pages frontend URL (used for CORS)
# Example: https://yourusername.github.io
FRONTEND_URL=https://yourusername.github.io
